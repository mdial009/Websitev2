4","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"66","messages":"67","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"68","messages":"69","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"70","messages":"71","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Footer.js",["72"],"import React, { useState, useEffect } from \"react\";\nimport \"./Footer.css\";\nimport { Button } from \"./Button\";\nimport { Link } from \"react-router-dom\";\nimport logo from \"../images/MadanyLogo5.png\";\n\nfunction Footer() {\n  const [githubInfo, setGitHubInfo] = useState({\n    stars: null,\n    forks: null,\n  });\n\n  useEffect(() => {\n    if (process.env.NODE_ENV !== \"production\") {\n      return;\n    }\n    fetch(\"https://api.github.com/users/mdial009\")\n      .then((response) => response.json())\n      .then((json) => {\n        const { followers, public_repos, blog, following } = json;\n        setGitHubInfo({\n          followers: followers,\n          repos: public_repos,\n          blogs: blog,\n          following: following,\n        });\n      })\n      .catch((e) => console.error(e));\n  }, []);\n  return (\n    <div className=\"footer-container\">\n      <section className=\"footer-subscription\">\n        <span>04. Contact</span>\n        <p className=\"footer-heading\">\n          <h2>\n            Get <span> In</span> Touch\n          </h2>\n        </p>\n        <p className=\"footer-text\">\n          Although I'<span>m</span> not currently looking for any new\n          opportunities, <span>m</span>y inbox is always open. Whether you have\n          a question or just want to say hi, I'll try <span>m</span>y best to\n          get back to you! at any ti<span>m</span>e.\n        </p>\n        <div className=\"input-areas\">\n          <form>\n            <input\n              className=\"footer-input\"\n              name=\"email\"\n              type=\"email\"\n              placeholder=\"Your Email\"\n            />\n            <Button buttonStyle=\"btn--primary\" buttonSize=\"btn--large\">\n              Hit Me Up 😉\n            </Button>\n          </form>\n        </div>\n      </section>\n      <div class=\"footer-links\">\n        <div className=\"footer-link-wrapper\">\n          <div class=\"footer-link-items\">\n            <h2>\n              Contact <span>M</span>e\n            </h2>\n            <Link to=\"/\">\n              <span>M</span>adanyx@g<span>m</span>ail.co<span>m</span>\n            </Link>\n            <Link to=\"/\">\n              <span>M</span>adanydiallo@aol.co<span>m</span>\n            </Link>\n          </div>\n        </div>\n        <div className=\"footer-link-wrapper\">\n          <div class=\"footer-link-items\">\n            <h2>\n              Social <span>M</span>edia\n            </h2>\n            <Link to=\"/\">\n              Instagra<span>m</span>\n            </Link>\n            <Link to=\"/\" href=\"https://www.facebook.com/madany.diallo.7\">\n              Facebook\n            </Link>\n            <Link to=\"/\">Youtube</Link>\n            <Link to=\"/\">Twitter</Link>\n          </div>\n        </div>\n      </div>\n      <section class=\"social-media\">\n        <div class=\"social-media-wrap\">\n          <div class=\"footer-logo\">\n            <Link to=\"/\" className=\"social-logo\">\n              <img className=\"social-logo\" src={logo} />\n            </Link>\n          </div>\n          <small class=\"website-rights\">\n            <a\n              class=\"website-rights\"\n              href=\"https://github.com/mdial009/Websitev2\"\n            >\n              {\" \"}\n              Madany Diallo © 2020{\" \"}\n            </a>\n            <a class=\"website-rights\" href=\"https://github.com/mdial009\">\n              {githubInfo.followers &&\n                githubInfo.repos &&\n                githubInfo.following && (\n                  <div>\n                    Followers:{githubInfo.followers.toLocaleString()}{\" \"}\n                    <span> </span>\n                    Repos:{githubInfo.repos.toLocaleString()}\n                    <span> </span>\n                    Following:{githubInfo.following.toLocaleString()}\n                  </div>\n                )}\n            </a>\n            <a class=\"website-rights\" href=\"https://mdial009.github.io\">\n              {githubInfo.blogs && (\n                <div>{githubInfo.blogs.toLocaleString()}</div>\n              )}\n            </a>\n          </small>\n          <div class=\"social-icons\">\n            <Link\n              class=\"social-icon-link facebook\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Facebook\"\n            >\n              <i\n                href=\"https://www.facebook.com/madany.diallo.7\"\n                class=\"fab fa-facebook-f\"\n              />\n            </Link>\n            <Link\n              class=\"social-icon-link instagram\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Instagram\"\n            >\n              <i class=\"fab fa-instagram\" />\n            </Link>\n            <Link\n              class=\"social-icon-link youtube\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Youtube\"\n            >\n              <i class=\"fab fa-youtube\" />\n            </Link>\n            <Link\n              class=\"social-icon-link twitter\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Twitter\"\n            >\n              <i class=\"fab fa-twitter\" />\n            </Link>\n            <Link\n              class=\"social-icon-link linkedin\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"LinkedIn\"\n            >\n              <i class=\"fab fa-linkedin\" />\n            </Link>\n            <Link\n              class=\"social-icon-link github\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"LinkedIn\"\n            >\n              <i class=\"fab fa-github\" />\n            </Link>\n          </div>\n        </div>\n      </section>\n    </div>\n  );\n}\n\nexport default Footer;\n",["73","74"],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/MenuItems.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Navbar.js",["75","76","77"],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Dropdown.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Button.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/App.js",["78","79","80"],"import React from \"react\";\nimport Navbar from \"./components/Navbar\";\nimport \"./App.css\";\nimport { BrowserRouter as Router, Switch, Route } from \"react-router-dom\";\nimport About from \"./components/sections/About\";\nimport Footer from \"./components/Footer\";\nimport Experience from \"./components/sections/Experience\";\nimport Work from \"./components/sections/Work\";\n\n\nfunction App() {\n  return (\n    <Router>\n      <Navbar />\n      {/* /* <Route path=\"/\" exact component={Home} />\n      <Route path=\"/About\" component={About} />\n  <Route path=\"/Contact\" component={Contact} />  */}\n      <About />\n      <Experience />\n      <Work />\n      <Footer />\n    </Router>\n    \n  );\n}\n\nexport default App;\n",["81","82"],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/sections/About.js",[],["83","84"],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/sections/Work.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/sections/Experience.js",[],["85","86"],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/HTabs.js",[],"/Users/madany