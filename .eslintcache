unt":0,"usedDeprecatedRules":"39"},{"filePath":"60","messages":"61","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"62","messages":"63","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"64","messages":"65","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"66","messages":"67","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"68","messages":"69","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"70","messages":"71","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"72","messages":"73","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"39"},"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Footer.js",["74"],"import React, { useState, useEffect } from \"react\";\nimport \"./Footer.css\";\nimport { Button } from \"./Button\";\nimport { Link } from \"react-router-dom\";\nimport logo from \"../images/MadanyLogo5.png\";\n\nfunction Footer() {\n  const [githubInfo, setGitHubInfo] = useState({\n    stars: null,\n    forks: null,\n  });\n\n  useEffect(() => {\n    if (process.env.NODE_ENV !== \"production\") {\n      return;\n    }\n    fetch(\"https://api.github.com/users/mdial009\")\n      .then((response) => response.json())\n      .then((json) => {\n        const { followers, public_repos, blog, following } = json;\n        setGitHubInfo({\n          followers: followers,\n          repos: public_repos,\n          blogs: blog,\n          following: following,\n        });\n      })\n      .catch((e) => console.error(e));\n  }, []);\n  return (\n    <div className=\"footer-container\">\n      <section className=\"footer-subscription\">\n        <span>04. Contact</span>\n        <p className=\"footer-heading\">\n          <h2>\n            Get <span> In</span> Touch\n          </h2>\n        </p>\n        <p className=\"footer-text\">\n          Although I'<span>m</span> not currently looking for any new\n          opportunities, <span>m</span>y inbox is always open. Whether you have\n          a question or just want to say hi, I'll try <span>m</span>y best to\n          get back to you! at any ti<span>m</span>e.\n        </p>\n        <div className=\"input-areas\">\n          <form>\n            <input\n              className=\"footer-input\"\n              name=\"email\"\n              type=\"email\"\n              placeholder=\"Your Email\"\n            />\n            <Button buttonStyle=\"btn--primary\" buttonSize=\"btn--large\">\n              Hit Me Up 😉\n            </Button>\n          </form>\n        </div>\n      </section>\n      <div class=\"footer-links\">\n        <div className=\"footer-link-wrapper\">\n          <div class=\"footer-link-items\">\n            <h2>\n              Contact <span>M</span>e\n            </h2>\n            <Link to=\"/\">\n              <span>M</span>adanyx@g<span>m</span>ail.co<span>m</span>\n            </Link>\n            <Link to=\"/\">\n              <span>M</span>adanydiallo@aol.co<span>m</span>\n            </Link>\n          </div>\n        </div>\n        <div className=\"footer-link-wrapper\">\n          <div class=\"footer-link-items\">\n            <h2>\n              Social <span>M</span>edia\n            </h2>\n            <Link to=\"/\">\n              Instagra<span>m</span>\n            </Link>\n            <Link to=\"/\" href=\"https://www.facebook.com/madany.diallo.7\">\n              Facebook\n            </Link>\n            <Link to=\"/\">Youtube</Link>\n            <Link to=\"/\">Twitter</Link>\n          </div>\n        </div>\n      </div>\n      <section class=\"social-media\">\n        <div class=\"social-media-wrap\">\n          <div class=\"footer-logo\">\n            <Link to=\"/\" className=\"social-logo\">\n              <img className=\"social-logo\" src={logo} />\n            </Link>\n          </div>\n          <small class=\"website-rights\">\n            <a\n              class=\"website-rights\"\n              href=\"https://github.com/mdial009/Websitev2\"\n            >\n              {\" \"}\n              Madany Diallo © 2020{\" \"}\n            </a>\n            <a class=\"website-rights\" href=\"https://github.com/mdial009\">\n              {githubInfo.followers &&\n                githubInfo.repos &&\n                githubInfo.following && (\n                  <div>\n                    Followers:{githubInfo.followers.toLocaleString()}{\" \"}\n                    <span> </span>\n                    Repos:{githubInfo.repos.toLocaleString()}\n                    <span> </span>\n                    Following:{githubInfo.following.toLocaleString()}\n                  </div>\n                )}\n            </a>\n            <a class=\"website-rights\" href=\"https://mdial009.github.io\">\n              {githubInfo.blogs && (\n                <div>{githubInfo.blogs.toLocaleString()}</div>\n              )}\n            </a>\n          </small>\n          <div class=\"social-icons\">\n            <Link\n              class=\"social-icon-link facebook\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Facebook\"\n            >\n              <i\n                href=\"https://www.facebook.com/madany.diallo.7\"\n                class=\"fab fa-facebook-f\"\n              />\n            </Link>\n            <Link\n              class=\"social-icon-link instagram\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Instagram\"\n            >\n              <i class=\"fab fa-instagram\" />\n            </Link>\n            <Link\n              class=\"social-icon-link youtube\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Youtube\"\n            >\n              <i class=\"fab fa-youtube\" />\n            </Link>\n            <Link\n              class=\"social-icon-link twitter\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"Twitter\"\n            >\n              <i class=\"fab fa-twitter\" />\n            </Link>\n            <Link\n              class=\"social-icon-link linkedin\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"LinkedIn\"\n            >\n              <i class=\"fab fa-linkedin\" />\n            </Link>\n            <Link\n              class=\"social-icon-link github\"\n              to=\"/\"\n              target=\"_blank\"\n              aria-label=\"LinkedIn\"\n            >\n              <i class=\"fab fa-github\" />\n            </Link>\n          </div>\n        </div>\n      </section>\n    </div>\n  );\n}\n\nexport default Footer;\n",["75","76"],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/MenuItems.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Navbar.js",["77","78","79"],"import React, { useState } from \"react\";\nimport { Button } from \"./Button\";\nimport \"./Navbar.css\";\nimport Dropdown from \"./Dropdown\";\nimport logo from \"../images/MadanyLogo5.png\";\nimport { Link } from \"react-scroll\";\n\nfunction Navbar() {\n  const [click, setClick] = useState(false);\n  const [dropdown, setDropdown] = useState(false);\n\n  const handleClick = () => setClick(!click);\n\n  const closeMobileMenu = () => setClick(false);\n\n  const onMouseEnter = () => {\n    if (window.innerWidth < 960) {\n      setDropdown(false);\n    } else {\n      setDropdown(true);\n    }\n  };\n\n  const onMouseLeave = () => {\n    if (window.innerWidth < 960) {\n      setDropdown(false);\n    } else {\n      setDropdown(false);\n    }\n  };\n\n  return (\n    <>\n      <nav className=\"navbar\">\n        <h1>WORK IN PROGRESS</h1>\n        <Link to=\"/\" className=\"navbar-logo\" onClick={closeMobileMenu}>\n          <img src={logo} />\n        </Link>\n        <div className=\"menu-icon\" onClick={handleClick}>\n          <i className={click ? \"fas fa-times\" : \"fas fa-bars\"} />\n        </div>\n        <ul className={click ? \"nav-menu active \" : \"nav-menu\"}>\n          <li className=\"nav-item\">\n            <Link to=\"About\" className=\"nav-links\" onClick={closeMobileMenu}>\n              <span>01. </span>About\n            </Link>\n          </li>\n          <li\n            className=\"nav-item\"\n            onMouseEnter={onMouseEnter}\n            onMouseLeave={onMouseLeave}\n          >\n            <Link\n              to=\"Experience\"\n              className=\"nav-links\"\n              onClick={closeMobileMenu}\n            >\n              <span>02. </span>Experience{\" \"}\n              {/*<i className=\"fas fa-caret-down\" /> */}\n            </Link>\n            {/*dropdown && <Dropdown /> */}\n          </li>\n          <li className=\"nav-item\">\n            <Link to=\"Work\" className=\"nav-links\" onClick={closeMobileMenu}>\n              <span>03. </span>Work\n            </Link>\n          </li>\n          <li className=\"nav-item\">\n            <Link\n              to=\"footer-container\"\n              className=\"nav-links\"\n              onClick={closeMobileMenu}\n            >\n              <span>04. </span>Contact\n            </Link>\n          </li>\n          <li>\n            <Link\n              to=\"/sign-up\"\n              className=\"nav-links-mobile\"\n              onClick={closeMobileMenu}\n            >\n              Résumé\n            </Link>\n          </li>\n        </ul>\n        <Button>Résumé</Button>\n      </nav>\n    </>\n  );\n}\n\nexport default Navbar;\n","/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Dropdown.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/Button.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/App.js",["80","81"],"import React from \"react\";\nimport Navbar from \"./components/Navbar\";\nimport \"./App.css\";\nimport { BrowserRouter as Router, Switch, Route } from \"react-router-dom\";\nimport About from \"./components/sections/About\";\nimport Footer from \"./components/Footer\";\nimport Experience from \"./components/sections/Experience\";\nimport Work from \"./components/sections/Work\";\n\n\nfunction App() {\n  return (\n    <Router>\n      <Navbar />\n      {/* /* <Route path=\"/\" exact component={Home} />\n      <Route path=\"/About\" component={About} />\n  <Route path=\"/Contact\" component={Contact} />  */}\n      <About />\n      <Experience />\n      <Work />\n      <Footer />\n    </Router>\n    \n  );\n}\n\nexport default App;\n","/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/sections/About.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/sections/Work.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/sections/Experience.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/HTabs.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/cards/Portfolio.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/cards/GithubUsers.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/cards/StockWeb.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/cards/VirtualAssistant.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/cards/AI-Chat-Bot.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/components/cards/ICM.js",[],"/Users/madanydiallo/Desktop/Websitev2/websitev2/src/index.js",[],{"ruleId":"82","severity":1,"message":"83","line":93,"column":15,"nodeType":"84","endLine":93,"endColumn":57},{"ruleId":"85","replacedBy":"86"},{"ruleId":"87","replacedBy":"88"},{"ruleId":"89","severity":1,"message":"90","line":4,"column":8,"nodeType":"91","messageId":"92","endLine":4,"endColumn":16},{"ruleId":"89","severity":1,"message":"93","line":10,"column":10,"node